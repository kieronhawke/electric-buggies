{
  "ci": {
    "collect": {
      "url": [
        "https://electric-buggies.vercel.app/",
        "https://electric-buggies.vercel.app/range/the-six",
        "https://electric-buggies.vercel.app/configure",
        "https://electric-buggies.vercel.app/locations/dubai",
        "https://electric-buggies.vercel.app/blog/lithium-vs-lead-acid-range-lifespan"
      ],
      "numberOfRuns": 1,
      "settings": { "preset": "desktop" }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }]
      }
    },
    "upload": { "target": "filesystem", "outputDir": ".lighthouseci" }
  }
}
